#!/usr/bin/env bash
#
# claude-cowork launcher for immutable (ostree) systems.
#
# The image ships the claude-cowork-linux source read-only under /usr/share.
# Its upstream install/launch flow writes into the working tree and the user's
# home and downloads Anthropic's proprietary Claude Desktop at runtime, so we
# mirror the source into a writable per-user copy and drive it from there
# (the same strategy the upstream Nix flake uses).
#
# Usage:
#   claude-cowork                first run downloads & patches Claude Desktop,
#                                subsequent runs launch it
#   claude-cowork --force        skip the download confirmation prompt
#   claude-cowork --doctor       run upstream preflight diagnostics
#   claude-cowork --reinstall    wipe the per-user copy and re-run install
#
set -euo pipefail

SRC=/usr/share/claude-cowork-linux
DEST="${XDG_DATA_HOME:-$HOME/.local/share}/claude-cowork-linux"

if [[ ! -d "$SRC" ]]; then
  echo "claude-cowork: $SRC not found; this image was not built with claude-cowork-linux." >&2
  exit 1
fi

if [[ "${1:-}" == "--reinstall" ]]; then
  shift
  # Wipe both the reviewed source mirror and install.sh's own app tree plus the
  # launchers it generates, so the reinstall actually starts clean. (install.sh
  # installs into ~/.local/share/claude-desktop, not $DEST, and writes its own
  # ~/.local/bin launchers that otherwise shadow this one.)
  rm -rf -- "$DEST" \
    "${XDG_DATA_HOME:-$HOME/.local/share}/claude-desktop" \
    "$HOME/.local/bin/claude-desktop" \
    "$HOME/.local/bin/claude-cowork"
fi

# Mirror the image's reviewed source into the writable per-user copy while
# preserving the extracted proprietary app. --delete prevents removed or
# renamed upstream files from lingering indefinitely across image updates.
mkdir -p "$DEST"
rsync -a --delete \
  --exclude='linux-app-extracted/' \
  "$SRC/" "$DEST/"

cd "$DEST"

# --doctor is handled by install.sh only (launch.sh takes no flags), and it
# works both before and after install, so route it there explicitly.
if [[ "${1:-}" == "--doctor" ]]; then
  exec ./install.sh --doctor
fi

# First run: extract & patch Claude Desktop into the user's home. install.sh
# prompts before downloading the proprietary DMG; pass --force to skip it.
#
# install.sh installs into its own INSTALL_DIR ($HOME/.local/share/claude-desktop)
# and extracts to linux-app-extracted THERE, not under $DEST. Detect first-run
# against that path, or the wrapper re-runs the whole installer (DMG download and
# all) on every invocation.
APP_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/claude-desktop"
if [[ ! -d "$APP_DIR/linux-app-extracted" ]]; then
  echo "claude-cowork: first run — installing Claude Desktop into your home."
  echo "claude-cowork: this downloads Anthropic's proprietary Claude Desktop DMG."
  exec ./install.sh "$@"
fi

# Already installed: hand off to the launcher install.sh generated. launch.sh
# only works relative to $APP_DIR (it repacks linux-app-extracted/ next to
# itself), so drive the app through that launcher rather than the copy in $DEST.
exec "$HOME/.local/bin/claude-desktop" "$@"
