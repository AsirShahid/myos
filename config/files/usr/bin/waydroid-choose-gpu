#!/usr/bin/bash

# Vendored from https://github.com/ublue-os/waydroid-scripts
# (waydroid-choose-gpu.sh, main branch, fetched 2026-07-06). Bazzite curls
# this at build time; we pin a copy instead. Binds the chosen GPU's DRI
# nodes into the Waydroid LXC config. Writes /var/lib/waydroid — run as
# root; invoked via `ujust setup-waydroid` (gpu option).

lspci="$(lspci -nn | grep '\[03')" # https://pci-ids.ucw.cz/read/PD/03

echo -e "Please enter the GPU number you want to pass to WayDroid:\n"
gpus=()
i=0
while IFS= read lspci; do
	gpus+=("$lspci")
	echo "  $((++i)). $lspci"
done < <(echo "$lspci")
echo ""
while [ -z "$gpuchoice" ]; do
	read -erp ">> Number of GPU to pass to WayDroid (1-${#gpus[@]}): " ans
	if [[ "$ans" =~ [0-9]+ && $ans -ge 1 && $ans -le ${#gpus[@]} ]]; then
		gpuchoice="${gpus[$((ans-1))]%% *}" # e.g. "26:00.0"
	fi
done

echo ""
echo "Confirm that these belong to your GPU:"
echo ""

ls -l /dev/dri/by-path/ | grep -i "$gpuchoice"

echo ""

# [0-9]+ (not [1-9][1-9][1-9]): match card10+, renderD130+, and any single-digit
# card too. The old pattern silently produced an empty match on those, leaving a
# broken mount entry.
card=$(ls -l /dev/dri/by-path/ | grep -i "$gpuchoice" | grep -o "card[0-9]\+" | head -n1)
rendernode=$(ls -l /dev/dri/by-path/ | grep -i "$gpuchoice" | grep -o "renderD[0-9]\+" | head -n1)

echo /dev/dri/$card
echo /dev/dri/$rendernode

if [ -z "$card" ] || [ -z "$rendernode" ]; then
	echo "Could not resolve the card/render node for GPU $gpuchoice; aborting without touching the Waydroid config." >&2
	exit 1
fi

CONFIG=/var/lib/waydroid/lxc/waydroid/config_nodes
if [ ! -f "$CONFIG" ]; then
	echo "Waydroid isn't initialized yet ($CONFIG missing). Run 'ujust setup-waydroid init' first." >&2
	exit 1
fi

cp "$CONFIG" "$CONFIG.bak"
#lxc.mount.entry = /dev/dri dev/dri none bind,create=dir,optional 0 0
sed -i '/dri/d' "$CONFIG"
echo "lxc.mount.entry = /dev/dri/$card dev/dri/card0 none bind,create=file,optional 0 0" >> "$CONFIG"
echo "lxc.mount.entry = /dev/dri/$rendernode dev/dri/renderD128 none bind,create=file,optional 0 0" >> "$CONFIG"
